PORT=5000
CONTACT_EMAIL=info@fineraglobal.com
# Optional extras only — production domains are always allowed in code
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional — save submissions to MongoDB
# MONGO_URI=mongodb://localhost:27017/contacts

# Optional — use your own SMTP (only needed if calling /api/contact from a server)
# Note: FormSubmit cannot be used from Render — Cloudflare blocks it.
# The website contact form submits FormSubmit from the browser instead.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Finera Global <your@email.com>"
    